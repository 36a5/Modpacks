# packwiz exports
*.mrpack
pack/*.zip
pack-two/*.zip

# server runtime (everything generated by Forge/packwiz-installer at runtime)
server/run/

# world backups created by reset-world.ps1
server/world-backup-*/

# local tooling
*.log
.DS_Store

# scratch space for tools/ (scanned mod jars, generated CSVs)
.cache/

# Vanilla Minecraft compile dependency for tools/shababparty. Mojang's code, this repo is public --
# not ours to redistribute. build.sh reconstructs it locally from the minecolonies-fork FG cache.
tools/shababparty/libs/

# preserved MineColonies colony backups (large zips, machine-local safety copies)
server/colony-backups-safe/
