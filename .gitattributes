# packwiz hashes raw file bytes. If git rewrites line endings on checkout, every hash in
# index.toml mismatches on a different OS and `packwiz refresh` reports the index as stale.
# Every pack folder must therefore be byte-identical everywhere: LF, always.
pack/** text eol=lf
pack-two/** text eol=lf

* text=auto
*.sh text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf
