# Executed as the dragon. Summon the Herald on the ground next to the nearest fighter so it lands
# somewhere reachable rather than in mid-air where the dragon is. A netherite mini-boss: tanky,
# fast, hits hard, permanent Resistance, and drops its sword (always) and helmet (always) as reward.
execute as @a[distance=..120,limit=1,sort=nearest] at @s run summon minecraft:wither_skeleton ~ ~ ~ {CustomName:'{"text":"Herald of the Void","color":"dark_purple","bold":true}',CustomNameVisible:1b,PersistenceRequired:1b,Tags:["slb_herald","slb_add"],Health:180f,Attributes:[{Name:"generic.max_health",Base:180},{Name:"generic.movement_speed",Base:0.34},{Name:"generic.attack_damage",Base:15},{Name:"generic.armor",Base:12},{Name:"generic.knockback_resistance",Base:0.85}],HandItems:[{id:"minecraft:netherite_sword",Count:1b,tag:{Enchantments:[{id:"minecraft:sharpness",lvl:4},{id:"minecraft:fire_aspect",lvl:2}]}},{}],ArmorItems:[{id:"minecraft:netherite_boots",Count:1b},{id:"minecraft:netherite_leggings",Count:1b},{id:"minecraft:netherite_chestplate",Count:1b},{id:"minecraft:netherite_helmet",Count:1b}],HandDropChances:[1.0f,0.0f],ArmorDropChances:[0.1f,0.1f,0.1f,1.0f],ActiveEffects:[{Id:11,Amplifier:1,Duration:2147483647,ShowParticles:0b}]}
